{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "byte-village": {
      "projectType": "application",
      "schematics": {},
      "root": "",
      "sourceRoot": "src",
      "prefix": "bv",
      "i18n": {
        "sourceLocale": "en",
        "locales": {
          "fr": "src/locale/messages.fr.xlf",
          "sw": "src/locale/messages.sw.xlf"
        }
      },
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/byte-village",
            "index": "src/index.html",
            "browser": "src/main.ts",
            "polyfills": ["zone.js", "@angular/localize/init"],
            "tsConfig": "tsconfig.app.json",
            "assets": ["src/favicon.ico", "src/favicon.svg", "src/assets"],
            "styles": ["src/styles.css"],
            "scripts": [],
            "localize": false
          },
          "configurations": {
            "fr": { "localize": ["fr"] },
            "sw": { "localize": ["sw"] },
            "production": {
              "budgets": [
                { "type": "initial", "maximumWarning": "500kb", "maximumError": "1mb" }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "fr": { "buildTarget": "byte-village:build:development,fr" },
            "sw": { "buildTarget": "byte-village:build:development,sw" },
            "development": { "buildTarget": "byte-village:build:development" },
            "production": { "buildTarget": "byte-village:build:production" }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": { "buildTarget": "byte-village:build" }
        }
      }
    }
  },
  "cli": {
    "analytics": "6a4b7b53-4e9b-4eac-8723-51f01107b368"
  }
}
